# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# TradingAgents runtime config
TRADINGAGENTS_LLM_PROVIDER=ollama
TRADINGAGENTS_BACKEND_URL=http://localhost:11434/v1
TRADINGAGENTS_QUICK_THINK_LLM=qwen3:latest
TRADINGAGENTS_DEEP_THINK_LLM=qwen3:latest

# Ollama-compatible aliases used by docker-compose
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_QUICK_MODEL=qwen3:latest
OLLAMA_DEEP_MODEL=qwen3:latest
